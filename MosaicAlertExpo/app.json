{
  "expo": {
    "name": "MosaicAlert",
    "slug": "MosaicAlertExpo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "mosaicalert",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mosaicalert.app",
      "infoPlist": {
        "NSCameraUsageDescription": "MosaicAlert needs camera access to scan cassava leaves.",
        "NSSpeechRecognitionUsageDescription": "MosaicAlert uses text-to-speech to read scan results aloud."
      }
    },
    "android": {
      "package": "com.mosaicalert.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.INTERNET"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-dev-client",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 34,
            "targetSdkVersion": 34
          }
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "MosaicAlert needs camera access to scan cassava leaves.",
          "enableMicrophonePermission": false
        }
      ],
      [
        "react-native-fast-tflite",
        {
          "enableAndroidGpuLibraries": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3bf632e0-2a1d-4440-bd57-f17bc6744e74"
      }
    }
  }
}
