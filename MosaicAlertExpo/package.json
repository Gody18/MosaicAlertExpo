{
  "name": "mosaicalertexpo",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "preview:web": "expo start --web --port 8084",
    "preview:web:static": "npx serve web-export-test -p 8085",
    "preview:android": "expo start --android",
    "prebuild": "expo prebuild",
    "prebuild:android": "expo prebuild --platform android --clean",
    "build:android:release": "expo run:android --variant release",
    "build:apk:local": "expo prebuild --platform android && cd android && gradlew assembleRelease",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.12.0",
    "@react-navigation/stack": "^7.9.3",
    "buffer": "^6.0.3",
    "expo": "~56.0.8",
    "expo-build-properties": "~56.0.16",
    "expo-constants": "~56.0.16",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-image-manipulator": "~14.0.8",
    "expo-linking": "~56.0.13",
    "expo-status-bar": "~56.0.4",
    "jpeg-js": "^0.4.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-fast-tflite": "^1.6.1",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-sqlite-storage": "^6.0.1",
    "react-native-tts": "^4.1.1",
    "react-native-vision-camera": "^4.7.3",
    "react-native-web": "^0.21.2"
  },
  "private": true,
  "devDependencies": {
    "@types/react": "~19.2.14",
    "typescript": "~6.0.3"
  }
}
